{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build",
      "type": "shell",
      "command": "g++",
      "args": ["-g", "-o", "${fileDirname}/solution", "${file}"],
      "group": { "kind": "build", "isDefault": true },
      "problemMatcher": ["$gcc"]
    },
    {
      "label": "run tests",
      "type": "shell",
      "command": "${workspaceFolder}/run.sh ${fileDirname}",
      "group": { "kind": "test", "isDefault": true },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    }
  ]
}
